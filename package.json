{
    "name": "destiny-ghost-api",
    "version": "2.18.0",
    "description": "Node.js API for querying the Destiny database via SMS messages.",
    "main": "start.js",
    "type": "module",
    "scripts": {
        "coverage": "pnpm test:watch --coverage --run",
        "format": "remark . --quiet --frail --output",
        "lint": "biome check --write .",
        "lint:ci": "biome check .",
        "start:production": "NODE_ENV=production node --permission --allow-fs-read=./ --allow-fs-read=/agents/ --allow-fs-write=./databases --allow-fs-write=/var/ --allow-worker --allow-addons --allow-net --disable-warning=SecurityWarning --import=./helpers/permission-model-patch.js -r dotenv/config --max-old-space-size=8192 --unhandled-rejections=strict start.js",
        "start:dev": "NODE_ENV=development pnpm start",
        "start": "node -r dotenv/config --max-old-space-size=8192 --unhandled-rejections=strict start.js",
        "swagger": "rm -f openapi.json && swagger-jsdoc -d openapi.cjs ./**/*.routes.js -o openapi.json",
        "test": "pnpm test:watch --run",
        "test:watch": "NODE_ENV=test node -r dotenv/config node_modules/vitest/vitest.mjs",
        "prepare": "husky || true",
        "typecheck": "tsc --noEmit -p jsconfig.json"
    },
    "author": "Chris Paskvan",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/chrispaskvan/destiny-ghost-api"
    },
    "engines": {
        "node": ">=26.0.0 <27",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.33.0",
    "dependencies": {
        "@azure/cosmos": "^4.9.3",
        "@godaddy/terminus": "^4.12.1",
        "@google/genai": "^2.11.0",
        "@grpc/grpc-js": "^1.14.4",
        "@grpc/proto-loader": "^0.8.1",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@paralleldrive/cuid2": "^3.3.0",
        "@snyk/protect": "^1.1306.0",
        "applicationinsights": "^3.15.1",
        "awesome-phonenumber": "^7.8.0",
        "base64url": "^3.0.1",
        "bullmq": "^5.80.1",
        "compression": "^1.8.1",
        "connect-redis": "^9.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-session": "^1.19.0",
        "graphql": "^17.0.2",
        "graphql-http": "^1.22.4",
        "helmet": "^8.2.0",
        "html-to-text": "^10.0.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.11.1",
        "lru-cache": "^11.5.2",
        "nodemailer": "^9.0.3",
        "opossum": "^10.0.0",
        "p-limit": "^7.3.0",
        "p-throttle": "^8.1.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "qs": "^6.15.3",
        "rate-limiter-flexible": "^11.2.0",
        "redis": "^6.1.0",
        "rfc6902": "^5.2.0",
        "swagger-ui-express": "^5.0.1",
        "tinypool": "^2.1.0",
        "twilio": "^6.0.2",
        "yauzl": "^3.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.3",
        "@vitest/coverage-v8": "^4.1.10",
        "chance": "^1.1.13",
        "husky": "^9.1.7",
        "nock": "^14.0.16",
        "node-mocks-http": "^1.18.0",
        "pino-pretty": "^13.1.3",
        "remark-cli": "^12.0.1",
        "remark-lint-list-item-indent": "^4.0.1",
        "remark-preset-lint-consistent": "^6.0.1",
        "remark-preset-lint-recommended": "^7.0.1",
        "stream-json": "^3.5.0",
        "swagger-jsdoc": "^6.3.0",
        "typescript": "^7.0.2",
        "v8": "^0.1.0",
        "vitest": "^4.1.10"
    },
    "snyk": true,
    "pnpm": {
        "onlyBuiltDependencies": [
            "@google/genai",
            "msgpackr-extract",
            "protobufjs"
        ]
    }
}
