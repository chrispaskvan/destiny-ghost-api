# pnpm configuration — see adr-files/pnpm.md
#
# Co-locate the store with the project so it's always on the same
# filesystem as node_modules. This guarantees pnpm uses hardlinks
# (no fallback to copy or symlink across overlay boundaries) and
# keeps every read inside cwd, which the production Node permission
# model (--allow-fs-read=./) is configured to allow.
store-dir=./.pnpm-store
package-import-method=hardlink

# Match the node version constraint in package.json#engines.
engine-strict=true

# Install peer deps automatically rather than warning about them —
# matches npm's default behavior so the developer experience doesn't
# regress.
auto-install-peers=true
